{
  "image": "mcr.microsoft.com/devcontainers/base",
  "hostRequirements": {
    "cpus": 4
  },
  "features":{
    "ghcr.io/devcontainers/features/node:2": {
      "version": "lts" // Installs the current LTS version using the v2 installer script
    }
  },
  "waitFor": "onCreateCommand",
  "updateContentCommand": "npm install",
  "postCreateCommand": "curl -fsSL https://opencode.ai/install | bash",
  "postAttachCommand": {
    "server": "npm start"
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "src/App.jsx"
      ]
    },
    "vscode": {
      "extensions": [
        "sst-dev.opencode"
      ]
    }
  },
  "portsAttributes": {
    "3000": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [3000]
}
